# Simple-GPT 插件配置示例
# 将以下配置复制到你的 .env 或 .env.prod 文件中

# ============================================
# 时间天气插件配置 (datetime_weather)
# ============================================

# 高德地图 API Key（从 https://console.amap.com/dev/key/app 获取）
# 留空则只显示时间，不显示天气
SIMPLE_GPT_WEATHER_API_KEY=

# 城市编码（高德地图城市编码）
# 常用城市编码：
#   110000 = 北京市
#   310000 = 上海市
#   440100 = 广州市
#   440300 = 深圳市
#   330100 = 杭州市
#   320100 = 南京市
#   500000 = 重庆市
#   510100 = 成都市
# 更多城市编码查询：https://lbs.amap.com/api/webservice/guide/api/district
SIMPLE_GPT_WEATHER_CITY=

# 天气 API 请求超时时间（秒），默认 5.0
# SIMPLE_GPT_WEATHER_TIMEOUT=5.0

# ============================================
# 网络搜索插件配置 (web_search)
# ============================================

# 是否启用网络搜索功能（true/false），默认 false
SIMPLE_GPT_SEARCH_ENABLED=true

# 用于判断是否需要搜索的 API Key（留空则使用主系统的 SIMPLE_GPT_API_KEY）
SIMPLE_GPT_SEARCH_CHECK_API_KEY=

# 用于判断是否需要搜索的 API Base URL（留空则使用主系统的 SIMPLE_GPT_API_BASE）
SIMPLE_GPT_SEARCH_CHECK_BASE_URL=

# 用于判断是否需要搜索的模型
SIMPLE_GPT_SEARCH_CHECK_MODEL=gemini-2.5-flash-lite

# 豆包搜索 API Key (doubao-seed)
SIMPLE_GPT_SEARCH_API_KEY=

# 豆包搜索 API Base URL
SIMPLE_GPT_SEARCH_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# 豆包搜索模型
SIMPLE_GPT_SEARCH_MODEL=doubao-seed-1-6-lite-251015

# ============================================
# 使用示例
# ============================================
#
# 启用时间和天气功能：
#   SIMPLE_GPT_WEATHER_API_KEY=your_amap_api_key_here
#   SIMPLE_GPT_WEATHER_CITY=110000
#
# 只启用时间（不显示天气）：
#   保持 API_KEY 和 CITY 为空或不设置
#
# 效果示例：
#   [当前时间：2025年12月22日 14:30:45 星期日] [天气：北京 晴 15℃ 北风3级 湿度45%]
#
# 启用网络搜索功能：
#   SIMPLE_GPT_SEARCH_ENABLED=true
#   SIMPLE_GPT_SEARCH_API_KEY=your_doubao_api_key_here
#
#   # 以下配置为可选，留空则使用主系统配置
#   SIMPLE_GPT_SEARCH_CHECK_API_KEY=your_check_api_key_here  # 留空使用 SIMPLE_GPT_API_KEY
#   SIMPLE_GPT_SEARCH_CHECK_BASE_URL=https://custom.api/v1  # 留空使用 SIMPLE_GPT_API_BASE
#
# 效果示例：
#   用户问题：鹰角网络最近有什么新发布的游戏吗？
#   插件会自动判断需要搜索，然后将搜索结果添加到 prompt 底部：
#   这是用来参考的搜索结果：【...搜索到的内容...】
#
